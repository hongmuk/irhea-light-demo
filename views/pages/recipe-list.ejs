<!-- Recipe List Page -->
<div class="page-content">
  <div class="section-header mb-20">
    <div>
      <h2 class="section-title">Recipes</h2>
      <p class="section-subtitle">Manage your pour-over recipes</p>
    </div>
  </div>

  <!-- Filters -->
  <div class="flex items-center gap-16 mb-20" style="flex-wrap:wrap;">
    <div class="search-bar">
      <span class="search-icon">&#128269;</span>
      <input type="text" id="recipe-search" placeholder="Search recipes..." />
    </div>
    <div class="filter-pills" id="dripper-filters">
      <button class="filter-pill active" data-filter="all">All</button>
      <button class="filter-pill" data-filter="V60">V60</button>
      <button class="filter-pill" data-filter="Kalita Wave">Kalita Wave</button>
      <button class="filter-pill" data-filter="Chemex">Chemex</button>
    </div>
    <div style="margin-left:auto;">
      <select class="form-input" id="recipe-sort" style="width:auto;min-height:40px;padding:8px 40px 8px 12px;">
        <option value="name">Sort by Name</option>
        <option value="recent">Sort by Recent</option>
        <option value="water">Sort by Water</option>
      </select>
    </div>
  </div>

  <!-- Recipe Grid -->
  <div class="grid-3" id="recipe-grid"></div>
</div>
