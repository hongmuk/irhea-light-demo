<!-- Recipe Detail Page -->
<div class="page-content">
  <div class="flex items-center gap-16 mb-24">
    <a href="/recipes" class="btn btn-ghost btn-icon">&#8592;</a>
    <div style="flex:1;">
      <h2 class="section-title" id="recipe-name">Loading...</h2>
      <p class="section-subtitle" id="recipe-dripper"></p>
    </div>
    <button class="btn btn-ghost btn-icon" id="fav-toggle" title="Toggle Favorite">&#9734;</button>
    <a class="btn btn-secondary" id="edit-link" href="#">&#9998; Edit</a>
    <button class="btn btn-primary" id="brew-btn">&#9654; Brew</button>
  </div>

  <div class="grid-2 mb-24">
    <!-- Parameters -->
    <div class="glass-card glass-card-lg">
      <h3 style="font-size:16px;font-weight:600;color:var(--text-primary);margin-bottom:16px;">Parameters</h3>
      <div class="info-grid" id="recipe-params"></div>
    </div>

    <!-- Stage Timeline -->
    <div class="glass-card glass-card-lg">
      <h3 style="font-size:16px;font-weight:600;color:var(--text-primary);margin-bottom:16px;">Extraction Stages</h3>
      <div id="stage-timeline" style="margin-bottom:16px;"></div>
      <div id="stage-bars"></div>
    </div>
  </div>

  <!-- Notes -->
  <div class="glass-card glass-card-lg mb-24">
    <h3 style="font-size:16px;font-weight:600;color:var(--text-primary);margin-bottom:12px;">Notes</h3>
    <p id="recipe-notes" style="color:var(--text-secondary);line-height:1.6;font-size:14px;"></p>
  </div>

  <!-- Stage Details Table -->
  <div class="glass-card glass-card-lg">
    <h3 style="font-size:16px;font-weight:600;color:var(--text-primary);margin-bottom:16px;">Stage Details</h3>
    <table class="data-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Type</th>
          <th>Label</th>
          <th>Time</th>
          <th>Water</th>
          <th>Spiral</th>
        </tr>
      </thead>
      <tbody id="stage-table"></tbody>
    </table>
  </div>
</div>
