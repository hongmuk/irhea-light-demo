<!-- Recipe Edit Page -->
<div class="page-content">
  <div class="flex items-center gap-16 mb-24">
    <a class="btn btn-ghost btn-icon" id="back-link" href="#">&#8592;</a>
    <div style="flex:1;">
      <h2 class="section-title">Edit Recipe</h2>
      <p class="section-subtitle" id="edit-recipe-name"></p>
    </div>
    <button class="btn btn-secondary" id="btn-cancel">Cancel</button>
    <button class="btn btn-primary" id="btn-save">&#10003; Save</button>
  </div>

  <div class="grid-2 mb-24">
    <!-- Basic Info -->
    <div class="glass-card glass-card-lg">
      <h3 style="font-size:16px;font-weight:600;color:var(--text-primary);margin-bottom:16px;">Basic Information</h3>
      <div class="form-group">
        <label class="form-label">Recipe Name</label>
        <input class="form-input" type="text" id="edit-name" />
      </div>
      <div class="grid-2">
        <div class="form-group">
          <label class="form-label">Dripper</label>
          <select class="form-input" id="edit-dripper">
            <option value="V60">V60</option>
            <option value="Kalita Wave">Kalita Wave</option>
            <option value="Chemex">Chemex</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Grind Size (clicks)</label>
          <input class="form-input" type="number" id="edit-grind" min="1" max="40" />
        </div>
      </div>
      <div class="grid-2">
        <div class="form-group">
          <label class="form-label">Coffee (g)</label>
          <input class="form-input" type="number" id="edit-coffee" min="5" max="50" />
        </div>
        <div class="form-group">
          <label class="form-label">Water (ml)</label>
          <input class="form-input" type="number" id="edit-water" min="50" max="1000" />
        </div>
      </div>
      <div class="grid-2">
        <div class="form-group">
          <label class="form-label">Temperature (°C)</label>
          <input class="form-input" type="number" id="edit-temp" min="85" max="98" />
        </div>
        <div class="form-group">
          <label class="form-label">Ratio</label>
          <input class="form-input" type="text" id="edit-ratio" placeholder="1:16" />
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Notes</label>
        <textarea class="form-input" id="edit-notes" rows="3"></textarea>
      </div>
    </div>

    <!-- Stage Preview -->
    <div class="glass-card glass-card-lg">
      <h3 style="font-size:16px;font-weight:600;color:var(--text-primary);margin-bottom:16px;">Stage Preview</h3>
      <div id="edit-timeline-preview"></div>
      <div style="margin-top:16px;">
        <div id="edit-validation" style="font-size:13px;"></div>
      </div>
    </div>
  </div>

  <!-- Stages Editor -->
  <div class="glass-card glass-card-lg">
    <div class="section-header mb-16">
      <h3 class="section-title">Extraction Stages</h3>
      <button class="btn btn-secondary btn-sm" id="btn-add-stage">+ Add Stage</button>
    </div>
    <div id="stages-container"></div>
  </div>
</div>
