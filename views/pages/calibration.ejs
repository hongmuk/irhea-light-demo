<!-- Calibration Page -->
<div class="page-content">
  <div class="section-header mb-20">
    <div>
      <h2 class="section-title">Calibration</h2>
      <p class="section-subtitle">Adjust flow sensor gain values per spout</p>
    </div>
    <div class="flex gap-12">
      <button class="btn btn-secondary" id="btn-reset">Reset to Default</button>
      <button class="btn btn-primary" id="btn-save-cal">Save Calibration</button>
    </div>
  </div>

  <!-- Spout Tabs -->
  <div class="tabs mb-20" id="cal-tabs">
    <button class="tab-item active" data-spout="0">Spout 1</button>
    <button class="tab-item" data-spout="1">Spout 2</button>
    <button class="tab-item" data-spout="2">Spout 3</button>
    <button class="tab-item" data-spout="3">Spout 4</button>
    <button class="tab-item" data-spout="4">Spout 5</button>
  </div>

  <!-- Gain Editor -->
  <div class="glass-card glass-card-lg mb-24">
    <h3 style="font-size:16px;font-weight:600;color:var(--text-primary);margin-bottom:16px;">Gain Values</h3>
    <div id="gain-editor"></div>
  </div>

  <!-- Calibration Simulation -->
  <div class="glass-card glass-card-lg">
    <div class="section-header mb-16">
      <h3 class="section-title" style="font-size:16px;">Calibration Test</h3>
      <button class="btn btn-secondary btn-sm" id="btn-test">Run Test</button>
    </div>
    <div id="cal-result" style="font-size:14px;color:var(--text-secondary);">
      Click "Run Test" to simulate a calibration test pour on the selected spout.
    </div>
  </div>
</div>
