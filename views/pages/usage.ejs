<!-- Usage History Page -->
<div class="page-content">
  <div class="section-header mb-20">
    <div>
      <h2 class="section-title">Usage History</h2>
      <p class="section-subtitle">Brewing statistics and session log</p>
    </div>
  </div>

  <!-- Period Tabs -->
  <div class="tabs mb-20" id="period-tabs">
    <button class="tab-item active" data-period="daily">Daily</button>
    <button class="tab-item" data-period="weekly">Weekly</button>
    <button class="tab-item" data-period="monthly">Monthly</button>
  </div>

  <!-- Chart -->
  <div class="glass-card glass-card-lg mb-24">
    <h3 style="font-size:16px;font-weight:600;color:var(--text-primary);margin-bottom:20px;">Brew Count</h3>
    <div id="usage-chart" style="padding-bottom:32px;"></div>
  </div>

  <!-- Top Recipes -->
  <div class="grid-2 mb-24">
    <div class="glass-card glass-card-lg">
      <h3 style="font-size:16px;font-weight:600;color:var(--text-primary);margin-bottom:16px;">Top Recipes</h3>
      <div id="top-recipes"></div>
    </div>
    <div class="glass-card glass-card-lg">
      <h3 style="font-size:16px;font-weight:600;color:var(--text-primary);margin-bottom:16px;">Summary</h3>
      <div class="info-grid" id="usage-summary"></div>
    </div>
  </div>

  <!-- Session Log -->
  <div class="glass-card glass-card-lg">
    <div class="section-header mb-16">
      <h3 class="section-title" style="font-size:16px;">Session Log</h3>
    </div>
    <table class="data-table">
      <thead>
        <tr>
          <th>Time</th>
          <th>Recipe</th>
          <th>Spout</th>
          <th>Duration</th>
          <th>Water</th>
          <th>Avg Temp</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody id="session-log"></tbody>
    </table>
  </div>
</div>
