<!-- Spout Control Panel — Main Screen -->
<div class="page-content">
  <!-- Machine Status Bar -->
  <div class="machine-status-bar mb-16">
    <div class="mstatus-item">
      <span class="mstatus-icon">&#9832;</span>
      <span class="mstatus-label">Boiler</span>
      <span class="mstatus-value" id="ms-temp">92.8°C</span>
    </div>
    <div class="mstatus-item">
      <span class="mstatus-icon">&#9687;</span>
      <span class="mstatus-label">Water</span>
      <span class="mstatus-value" id="ms-water">72%</span>
    </div>
    <div class="mstatus-item">
      <span class="mstatus-icon">&#9041;</span>
      <span class="mstatus-label">Pressure</span>
      <span class="mstatus-value" id="ms-pressure">1.02 bar</span>
    </div>
    <div class="mstatus-divider"></div>
    <div class="mstatus-item">
      <span class="mstatus-icon" style="color:var(--status-ok);">&#9679;</span>
      <span class="mstatus-label">Active</span>
      <span class="mstatus-value" id="ms-active">1 / 5</span>
    </div>
    <div class="mstatus-item">
      <span class="mstatus-icon" style="color:var(--accent-amber);">&#9749;</span>
      <span class="mstatus-label">Today</span>
      <span class="mstatus-value" id="ms-today">18</span>
    </div>
  </div>

  <!-- 5 Spout Control Cards -->
  <div class="spout-control-grid" id="spout-control-grid">
    <!-- Rendered by JS -->
  </div>
</div>

<!-- Recipe Picker Modal -->
<div class="modal-overlay" id="recipe-modal-overlay" onclick="closeRecipeModal()"></div>
<div class="modal-panel" id="recipe-modal">
  <div class="modal-header">
    <h3>Select Recipe</h3>
    <span class="modal-spout-label" id="modal-spout-label">Spout 1</span>
    <button class="more-menu-close" onclick="closeRecipeModal()">&times;</button>
  </div>
  <div class="modal-search">
    <input type="text" placeholder="Search recipes..." id="modal-recipe-search" oninput="filterModalRecipes(this.value)" />
  </div>
  <div class="modal-recipe-list" id="modal-recipe-list">
    <!-- Rendered by JS -->
  </div>
</div>
