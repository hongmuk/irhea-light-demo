<!-- System Info Page -->
<div class="page-content">
  <div class="section-header mb-20">
    <div>
      <h2 class="section-title">System Information</h2>
      <p class="section-subtitle">Machine details and configuration</p>
    </div>
  </div>

  <div class="grid-2 mb-24">
    <!-- Machine Info -->
    <div class="glass-card glass-card-lg">
      <h3 style="font-size:16px;font-weight:600;color:var(--text-primary);margin-bottom:16px;">Machine</h3>
      <div class="info-grid" id="machine-info"></div>
    </div>

    <!-- Shop Info -->
    <div class="glass-card glass-card-lg">
      <h3 style="font-size:16px;font-weight:600;color:var(--text-primary);margin-bottom:16px;">Shop</h3>
      <div class="info-grid" id="shop-info"></div>
    </div>
  </div>

  <div class="grid-2 mb-24">
    <!-- Network -->
    <div class="glass-card glass-card-lg">
      <h3 style="font-size:16px;font-weight:600;color:var(--text-primary);margin-bottom:16px;">Network</h3>
      <div class="info-grid" id="network-info"></div>
    </div>

    <!-- Usage Stats -->
    <div class="glass-card glass-card-lg">
      <h3 style="font-size:16px;font-weight:600;color:var(--text-primary);margin-bottom:16px;">Usage Statistics</h3>
      <div class="info-grid" id="usage-stats"></div>
    </div>
  </div>

  <!-- Firmware Versions -->
  <div class="glass-card glass-card-lg">
    <h3 style="font-size:16px;font-weight:600;color:var(--text-primary);margin-bottom:16px;">Firmware Versions</h3>
    <div class="grid-3" id="fw-info"></div>
  </div>
</div>
