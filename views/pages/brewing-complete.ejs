<!-- Brewing Complete Page -->
<div class="page-content">
  <div class="flex items-center justify-center" style="min-height:calc(100vh - 140px);">
    <div style="text-align:center;max-width:500px;width:100%;">
      <!-- Complete Animation -->
      <div class="brew-complete-icon">&#10003;</div>
      <h2 style="font-size:28px;font-weight:700;color:var(--text-primary);margin-bottom:8px;">Brewing Complete!</h2>
      <p style="font-size:14px;color:var(--text-secondary);margin-bottom:32px;">Your pour-over is ready to serve</p>

      <!-- Result Summary -->
      <div class="glass-card glass-card-lg mb-24" style="text-align:left;">
        <h3 style="font-size:16px;font-weight:600;color:var(--text-primary);margin-bottom:16px;">Brew Summary</h3>
        <div class="info-grid">
          <div class="info-cell">
            <div class="info-label">Recipe</div>
            <div class="info-value">Ethiopia Yirgacheffe</div>
          </div>
          <div class="info-cell">
            <div class="info-label">Spout</div>
            <div class="info-value">Spout 1</div>
          </div>
          <div class="info-cell">
            <div class="info-label">Duration</div>
            <div class="info-value">3:15</div>
          </div>
          <div class="info-cell">
            <div class="info-label">Water Used</div>
            <div class="info-value">318 ml</div>
          </div>
          <div class="info-cell">
            <div class="info-label">Avg Temperature</div>
            <div class="info-value">92.8°C</div>
          </div>
          <div class="info-cell">
            <div class="info-label">Stages Completed</div>
            <div class="info-value">7 / 7</div>
          </div>
        </div>
      </div>

      <!-- Actions -->
      <div class="flex items-center justify-center gap-16">
        <button class="btn btn-secondary btn-lg" onclick="location.href=nav('/')">
          &#9632; Dashboard
        </button>
        <button class="btn btn-primary btn-lg" onclick="location.href=nav('/brewing')">
          &#9654; Brew Again
        </button>
      </div>
    </div>
  </div>
</div>
