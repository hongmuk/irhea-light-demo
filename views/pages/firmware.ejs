<!-- Firmware Page -->
<div class="page-content">
  <div class="section-header mb-20">
    <div>
      <h2 class="section-title">Firmware Update</h2>
      <p class="section-subtitle">Manage board firmware versions</p>
    </div>
  </div>

  <!-- Firmware Cards -->
  <div class="flex flex-col gap-16 mb-24" id="fw-cards"></div>

  <!-- Update Simulation -->
  <div class="glass-card glass-card-lg" id="update-panel" style="display:none;">
    <h3 style="font-size:16px;font-weight:600;color:var(--text-primary);margin-bottom:16px;">Firmware Update in Progress</h3>
    <div style="margin-bottom:12px;">
      <div class="flex justify-between mb-8">
        <span style="font-size:13px;color:var(--text-secondary);" id="update-board">Updating MCP-500...</span>
        <span style="font-size:13px;font-weight:600;color:var(--accent-amber);" id="update-percent">0%</span>
      </div>
      <div class="progress-bar-track">
        <div class="progress-bar-fill" id="update-bar" style="width:0%;"></div>
      </div>
    </div>
    <div style="font-size:12px;color:var(--text-muted);" id="update-status">Downloading firmware package...</div>
  </div>
</div>
