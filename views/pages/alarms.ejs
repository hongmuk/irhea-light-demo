<!-- Alarms Page -->
<div class="page-content">
  <div class="section-header mb-20">
    <div>
      <h2 class="section-title">Alarms</h2>
      <p class="section-subtitle">Active alarms and alarm history</p>
    </div>
  </div>

  <!-- Filter -->
  <div class="flex items-center gap-16 mb-20">
    <div class="filter-pills" id="alarm-filters">
      <button class="filter-pill active" data-filter="all">All</button>
      <button class="filter-pill" data-filter="MCP">MCP</button>
      <button class="filter-pill" data-filter="MDP">MDP</button>
      <button class="filter-pill" data-filter="WHP">WHP</button>
    </div>
  </div>

  <!-- Active Alarms -->
  <div class="glass-card glass-card-lg mb-24">
    <div class="section-header mb-16">
      <h3 class="section-title" style="font-size:16px;">Active Alarms</h3>
      <span class="alarm-badge mcp" id="active-count">3</span>
    </div>
    <div id="active-alarms-list"></div>
  </div>

  <!-- Alarm History -->
  <div class="glass-card glass-card-lg">
    <div class="section-header mb-16">
      <h3 class="section-title" style="font-size:16px;">Alarm History</h3>
    </div>
    <div id="alarm-history-list"></div>
  </div>
</div>
